# ── Backend (Railway) ────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=production

# PostgreSQL — Railway provides this automatically as $DATABASE_URL
DATABASE_URL=postgres://user:password@host:5432/railway?sslmode=require

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=change-me-generate-a-strong-secret-here

# CORS — set to your Vercel frontend URL
CORS_ORIGINS=https://orion-dashboard.vercel.app

# Optional
REDIS_URL=
OTLP_ENDPOINT=
LLM_API_KEY=
