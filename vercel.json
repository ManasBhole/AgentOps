{
  "buildCommand": "cd dashboard && npm install && npm run build",
  "outputDirectory": "dashboard/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://orion-api.onrender.com/api/:path*" },
    { "source": "/auth/:path*", "destination": "https://orion-api.onrender.com/auth/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
